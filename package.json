{
  "name": "agentic-text-composer",
  "version": "0.1.0",
  "description": "Local agentic markdown composer: WYSIWYG editor live-synced with a markdown file so humans and file-editing agents collaborate on one doc.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "compose": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup && vite build",
    "dev": "vite",
    "test": "vitest run",
    "e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "@fastify/websocket": "^11.0.1",
    "chokidar": "^3.6.0",
    "diff-match-patch": "^1.0.5",
    "fastify": "^5.10.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@tiptap/core": "^2.9.1",
    "@tiptap/extension-link": "^2.9.1",
    "@tiptap/extension-table": "^2.9.1",
    "@tiptap/extension-table-cell": "^2.9.1",
    "@tiptap/extension-table-header": "^2.9.1",
    "@tiptap/extension-table-row": "^2.9.1",
    "@tiptap/pm": "^2.9.1",
    "@tiptap/react": "^2.9.1",
    "@tiptap/starter-kit": "^2.9.1",
    "@types/diff-match-patch": "^1.0.36",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^4.3.1",
    "happy-dom": "^15.7.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tiptap-markdown": "^0.8.10",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "ws": "^8.18.0"
  }
}
